{
  "version": "1.0.0",
  "created": "2026-07-12",
  "description": "Rule validation matrix for all engineering rules",
  "rules": {
    "RULE-SEC-001": {
      "name": "No Hardcoded Secrets",
      "version": "1.0.0",
      "firstIntroduced": "1.0.0",
      "lastModified": "1.0.0",
      "stability": "stable",
      "gate": "Security",
      "severity": "Critical",
      "classification": "Security Vulnerability",
      "positiveExamples": [
        "Hardcoded API key in source code",
        "Password string literal in configuration",
        "Secret token in environment file"
      ],
      "negativeExamples": [
        "Environment variable reference",
        "Secret manager client",
        "Encrypted secret storage"
      ],
      "falsePositiveExamples": [
        "Test fixtures with dummy values",
        "Example configurations",
        "Documentation snippets"
      ],
      "falseNegativeRisks": [
        "Credentials exposed in source code",
        "Unauthorized access to APIs",
        "Data breach potential"
      ],
      "expectedEvidence": [
        "File path and line number",
        "Secret pattern match",
        "Context analysis"
      ],
      "expectedRecommendation": [
        "Use environment variables",
        "Use secret manager",
        "Remove hardcoded secrets"
      ],
      "expectedCertificationImpact": "Release Blocker"
    },
    "RULE-SEC-002": {
      "name": "No SQL Injection",
      "version": "1.0.0",
      "firstIntroduced": "1.0.0",
      "lastModified": "1.0.0",
      "stability": "stable",
      "gate": "Security",
      "severity": "Critical",
      "classification": "Security Vulnerability",
      "positiveExamples": [
        "String concatenation in SQL query",
        "Template literal in SQL query",
        "User input in SQL query"
      ],
      "negativeExamples": [
        "Parameterized query",
        "ORM usage",
        "Query builder"
      ],
      "falsePositiveExamples": [
        "ORM with parameterization",
        "Query builder with escaping"
      ],
      "falseNegativeRisks": [
        "SQL injection vulnerability",
        "Data breach potential",
        "Unauthorized data access"
      ],
      "expectedEvidence": [
        "File path and line number",
        "SQL query pattern",
        "Input source"
      ],
      "expectedRecommendation": [
        "Use parameterized queries",
        "Use ORM",
        "Sanitize user input"
      ],
      "expectedCertificationImpact": "Release Blocker"
    },
    "RULE-CODE-001": {
      "name": "No Unused Variables",
      "version": "1.0.0",
      "firstIntroduced": "1.0.0",
      "lastModified": "1.0.0",
      "stability": "stable",
      "gate": "Code Quality",
      "severity": "Low",
      "classification": "Engineering Recommendation",
      "positiveExamples": [
        "Variable declared but never used",
        "Import not used",
        "Function defined but never called"
      ],
      "negativeExamples": [
        "Variable used in expression",
        "Import used in code",
        "Function called in code"
      ],
      "falsePositiveExamples": [
        "TypeScript type-only imports",
        "React component imports",
        "Side-effect imports"
      ],
      "falseNegativeRisks": [
        "Code bloat",
        "Reduced readability",
        "Potential confusion"
      ],
      "expectedEvidence": [
        "File path and line number",
        "Unused variable name",
        "Lint output"
      ],
      "expectedRecommendation": [
        "Remove unused variable",
        "Clean up imports"
      ],
      "expectedCertificationImpact": "None"
    },
    "RULE-TYPE-001": {
      "name": "No Any Types",
      "version": "1.0.0",
      "firstIntroduced": "2.0.0",
      "lastModified": "2.0.0",
      "stability": "stable",
      "gate": "Type Safety",
      "severity": "Medium",
      "classification": "Engineering Recommendation",
      "positiveExamples": [
        "Explicit `any` type annotation",
        "Implicit `any` from missing type",
        "Type assertion bypassing type checking"
      ],
      "negativeExamples": [
        "Proper type annotation",
        "Type inference",
        "Type guard"
      ],
      "falsePositiveExamples": [
        "Third-party library integration",
        "Migration in progress",
        "Dynamic data from API"
      ],
      "falseNegativeRisks": [
        "Reduced type safety",
        "Runtime errors",
        "Harder debugging"
      ],
      "expectedEvidence": [
        "File path and line number",
        "Any type usage",
        "Context analysis"
      ],
      "expectedRecommendation": [
        "Replace `any` with proper type",
        "Use type guard",
        "Use unknown type"
      ],
      "expectedCertificationImpact": "None"
    },
