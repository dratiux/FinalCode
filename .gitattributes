# Auto detect text files and perform LF normalization
* text=auto

# Markdown files
*.md text diff=markdown

# YAML files
*.yml text
*.yaml text

# Image files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.svg text

# Ensure consistent line endings
*.md eol=lf
*.yml eol=lf
*.yaml eol=lf
*.json eol=lf
*.txt eol=lf


